                      </div>
                    </div>
                    <div className="mt-4 flex items-center text-sm">
                      <TrendingUp className="w-4 h-4 text-green-400 mr-1" />
                      <span className="text-green-400">+2 this month</span>
                    </div>
                  </CardContent>
                </Card>

                <Card className="bg-gradient-to-br from-[#9B59B6]/20 to-[#9B59B6]/5 border-[#9B59B6]/30">
                  <CardContent className="p-6">
                    <div className="flex items-center justify-between">
                      <div>
                        <p className="text-gray-400 text-sm">Completed Projects</p>
                        <p className="text-3xl font-bold text-white mt-1">{user.completedProjects}</p>
                      </div>
                      <div className="w-12 h-12 bg-[#9B59B6]/20 rounded-xl flex items-center justify-center">
                        <Check className="w-6 h-6 text-[#9B59B6]" />
                      </div>
                    </div>
                    <div className="mt-4 flex items-center text-sm">
                      <Star className="w-4 h-4 text-yellow-400 mr-1" />
                      <span className="text-gray-300">{user.rating} average rating</span>
                    </div>
                  </CardContent>
                </Card>

                <Card className="bg-gradient-to-br from-[#E74C3C]/20 to-[#E74C3C]/5 border-[#E74C3C]/30">
                  <CardContent className="p-6">
                    <div className="flex items-center justify-between">
                      <div>
                        <p className="text-gray-400 text-sm">Pending Reviews</p>
                        <p className="text-3xl font-bold text-white mt-1">{user.pendingReviews}</p>
                      </div>
                      <div className="w-12 h-12 bg-[#E74C3C]/20 rounded-xl flex items-center justify-center">
                        <Clock className="w-6 h-6 text-[#E74C3C]" />
                      </div>
                    </div>
                    <div className="mt-4 flex items-center text-sm">
                      <span className="text-gray-400">Awaiting client approval</span>
                    </div>
                  </CardContent>
                </Card>

                <Card className="bg-gradient-to-br from-[#F39C12]/20 to-[#F39C12]/5 border-[#F39C12]/30">
                  <CardContent className="p-6">
                    <div className="flex items-center justify-between">
                      <div>
                        <p className="text-gray-400 text-sm">Assistant Projects</p>
                        <p className="text-3xl font-bold text-white mt-1">
                          {user.skills.reduce((acc, skill) => acc + skill.assistantProjectsCompleted, 0)}
                        </p>
                      </div>
                      <div className="w-12 h-12 bg-[#F39C12]/20 rounded-xl flex items-center justify-center">
                        <Award className="w-6 h-6 text-[#F39C12]" />
                      </div>
                    </div>
                    <div className="mt-4 flex items-center text-sm">
                      <span className="text-gray-400">Towards architect status</span>
                    </div>
                  </CardContent>
                </Card>
              </div>

              {/* Recent Activity & Upcoming Deadlines */}
              <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
                {/* Recent Activity */}
                <Card className="bg-[#2a2a2a]/50 border-gray-800">
                  <CardHeader>
                    <CardTitle className="text-white">Recent Activity</CardTitle>
                  </CardHeader>
                  <CardContent>
                    <div className="space-y-4">
                      {[
                        { icon: Check, color: 'text-green-400', text: 'Completed "Minimalist House" project', time: '2 days ago' },
                        { icon: MessageCircle, color: 'text-blue-400', text: 'New message from John Smith', time: '1 hour ago' },
                        { icon: FileText, color: 'text-purple-400', text: 'Uploaded revision for Beachfront Resort', time: '3 hours ago' },
                        { icon: Video, color: 'text-cyan-400', text: 'Completed video meeting with Chef Marcus', time: '1 day ago' },
                      ].map((activity, idx) => (
                        <div key={idx} className="flex items-start gap-3">
                          <div className={`w-8 h-8 rounded-lg bg-gray-800 flex items-center justify-center flex-shrink-0 ${activity.color}`}>
                            <activity.icon className="w-4 h-4" />
                          </div>
                          <div className="flex-1 min-w-0">
                            <p className="text-sm text-white">{activity.text}</p>
                            <p className="text-xs text-gray-500">{activity.time}</p>
                          </div>
                        </div>
                      ))}
                    </div>
                  </CardContent>
                </Card>

                {/* Upcoming Deadlines */}
                <Card className="bg-[#2a2a2a]/50 border-gray-800">
                  <CardHeader>
                    <CardTitle className="text-white">Upcoming Deadlines</CardTitle>
                  </CardHeader>
                  <CardContent>
                    <div className="space-y-4">
                      {assignedProjects
                        .filter(p => p.status !== 'completed')
                        .sort((a, b) => new Date(a.deadline).getTime() - new Date(b.deadline).getTime())
                        .slice(0, 4)
                        .map((project) => (
                          <div key={project.id} className="flex items-center justify-between p-3 bg-gray-800/50 rounded-lg">
                            <div className="flex-1 min-w-0">
                              <p className="text-sm font-medium text-white truncate">{project.title}</p>
                              <p className="text-xs text-gray-400">{project.category}</p>
                            </div>
                            <div className="text-right ml-4">
                              <p className="text-sm text-[#E74C3C] font-medium">
                                {new Date(project.deadline).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                              </p>
                              <p className="text-xs text-gray-500">
                                {Math.ceil((new Date(project.deadline).getTime() - Date.now()) / (1000 * 60 * 60 * 24))} days left
                              </p>
                            </div>
                          </div>
                        ))}
                    </div>
                  </CardContent>
                </Card>
              </div>

              {/* Quick Actions */}
              <Card className="bg-[#2a2a2a]/50 border-gray-800">
                <CardHeader>
                  <CardTitle className="text-white">Quick Actions</CardTitle>
                </CardHeader>
                <CardContent>
                  <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
                    <Button
                      onClick={() => setActiveSection('inbox')}
                      className="h-24 flex-col bg-gradient-to-br from-[#6B5B95]/20 to-[#9B59B6]/20 border border-[#6B5B95]/30 hover:from-[#6B5B95]/30 hover:to-[#9B59B6]/30"
                    >
                      <Inbox className="w-8 h-8 mb-2" />
                      <span className="text-sm">View Inbox</span>
                    </Button>
                    <Button
                      onClick={() => setActiveSection('chat')}
                      className="h-24 flex-col bg-gradient-to-br from-[#9B59B6]/20 to-[#E74C3C]/20 border border-[#9B59B6]/30 hover:from-[#9B59B6]/30 hover:to-[#E74C3C]/30"
                    >
                      <MessageCircle className="w-8 h-8 mb-2" />
                      <span className="text-sm">Open Chat</span>
                    </Button>
                    <Button
                      onClick={() => setActiveSection('meetings')}
                      className="h-24 flex-col bg-gradient-to-br from-[#E74C3C]/20 to-[#F39C12]/20 border border-[#E74C3C]/30 hover:from-[#E74C3C]/30 hover:to-[#F39C12]/30"
                    >
                      <Video className="w-8 h-8 mb-2" />
                      <span className="text-sm">My Meetings</span>
                    </Button>
                    <Button
                      onClick={() => setActiveSection('portfolio')}
                      className="h-24 flex-col bg-gradient-to-br from-[#F39C12]/20 to-[#F1C40F]/20 border border-[#F39C12]/30 hover:from-[#F39C12]/30 hover:to-[#F1C40F]/30"
                    >
                      <ImageIcon className="w-8 h-8 mb-2" />
                      <span className="text-sm">Portfolio</span>
                    </Button>
                  </div>
                </CardContent>
              </Card>
            </div>
          )}

          {/* Inbox Section */}
          {activeSection === 'inbox' && (
            <div className="space-y-6">
              <div className="flex items-center justify-between">
                <div>
                  <h3 className="text-xl font-semibold text-white">New Project Requests</h3>
                  <p className="text-gray-400 text-sm mt-1">
                    {projectRequests.filter(p => p.status === 'pending').length} pending requests
                  </p>
                </div>
                <div className="flex items-center gap-2">
                  <Button variant="outline" size="sm" className="bg-[#2a2a2a] border-gray-700 text-white">
                    <Filter className="w-4 h-4 mr-2" />
                    Filter
                  </Button>
                </div>
              </div>

              <div className="space-y-4">
                {projectRequests.map((project) => (
                  <Card key={project.id} className="bg-[#2a2a2a]/50 border-gray-800 hover:border-[#6B5B95]/50 transition-colors">
                    <CardContent className="p-6">
                      <div className="flex items-start justify-between mb-4">
                        <div className="flex items-start gap-4">
                          <div className="w-12 h-12 bg-gradient-to-br from-[#6B5B95]/20 to-[#9B59B6]/20 rounded-xl flex items-center justify-center flex-shrink-0">
                            {getCategoryIcon(project.category)}
                          </div>
                          <div>
                            <h4 className="text-lg font-semibold text-white">{project.title}</h4>
                            <div className="flex items-center gap-2 mt-1">
                              <Badge variant="outline" className="bg-[#6B5B95]/20 text-[#9B59B6] border-[#6B5B95]/30">
                                {project.category}
                              </Badge>
                              {project.buildingType && (
                                <Badge variant="outline" className="bg-gray-800 text-gray-300 border-gray-700">
                                  {project.buildingType}
                                </Badge>
                              )}
                              {project.expertiseMatch ? (
                                <Badge className="bg-green-500/20 text-green-400">
                                  <Star className="w-3 h-3 mr-1" />
                                  Expertise Match
                                </Badge>
                              ) : (
                                <Badge variant="outline" className="bg-yellow-500/20 text-yellow-400 border-yellow-500/30">
                                  <Award className="w-3 h-3 mr-1" />
                                  Apply as Assistant
                                </Badge>
                              )}
                            </div>
                          </div>
                        </div>
                        <div className="flex items-center gap-2">
                          <p className="text-xs text-gray-500">
                            {new Date(project.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                          </p>
                        </div>
                      </div>

                      <p className="text-gray-300 text-sm mb-4">{project.description}</p>

                      <div className="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4">
                        <div className="flex items-center gap-2">
                          <DollarSign className="w-4 h-4 text-[#F39C12]" />
                          <div>
                            <p className="text-xs text-gray-500">Budget</p>
                            <p className="text-sm text-white">{project.budget}</p>
                          </div>
                        </div>
                        <div className="flex items-center gap-2">
                          <MapPin className="w-4 h-4 text-[#E74C3C]" />
                          <div>
                            <p className="text-xs text-gray-500">Location</p>
                            <p className="text-sm text-white">{project.location}</p>
                          </div>
                        </div>
                        <div className="flex items-center gap-2">
                          <Calendar className="w-4 h-4 text-[#9B59B6]" />
                          <div>
                            <p className="text-xs text-gray-500">Deadline</p>
                            <p className="text-sm text-white">
                              {new Date(project.deadline).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                            </p>
                          </div>
                        </div>
                        <div className="flex items-center gap-2">
                          <User className="w-4 h-4 text-[#6B5B95]" />
                          <div>
                            <p className="text-xs text-gray-500">Client</p>
                            <p className="text-sm text-white">{project.clientName}</p>
                          </div>
                        </div>
                        <div className="flex items-center gap-2">
                          <Button
                            variant="ghost"
                            size="sm"
                            onClick={() => handleViewProfile(project.clientName)}
                            className="h-8 text-[#9B59B6] hover:text-[#9B59B6] hover:bg-[#6B5B95]/10"
                          >
                            View Profile
                          </Button>
                        </div>
                      </div>

                      <div className="flex items-center justify-end gap-3 pt-4 border-t border-gray-700">
                        <Button
                          variant="outline"
                          size="sm"
                          onClick={() => handleDeclineProject(project.id)}
                          className="bg-red-500/10 border-red-500/30 text-red-400 hover:bg-red-500/20"
                        >
                          <X className="w-4 h-4 mr-2" />
                          Decline
                        </Button>
                        {project.expertiseMatch ? (
                          <Button
                            size="sm"
                            onClick={() => handleAcceptProject(project.id)}
                            className="bg-gradient-to-r from-[#6B5B95] to-[#9B59B6] hover:from-[#5a4a7e] hover:to-[#8a4a9f]"
                          >
                            <Check className="w-4 h-4 mr-2" />
                            Accept Project
                          </Button>
                        ) : (
                          <Button
                            size="sm"
                            onClick={() => handleApplyAsAssistant(project.id)}
                            className="bg-gradient-to-r from-[#F39C12] to-[#F1C40F] hover:from-[#e08b11] hover:to-[#e0d410] text-black"
                          >
                            <Award className="w-4 h-4 mr-2" />
                            Apply as Assistant
                          </Button>
                        )}
                      </div>
                    </CardContent>
                  </Card>
                ))}
              </div>
            </div>
          )}

          {/* Outbox Section */}
          {activeSection === 'outbox' && (
            <div className="space-y-6">
              <div className="flex items-center justify-between">
                <div>
                  <h3 className="text-xl font-semibold text-white">My Accepted Projects</h3>
                  <p className="text-gray-400 text-sm mt-1">
                    {assignedProjects.filter(p => p.status !== 'completed').length} active projects
                  </p>
                </div>
              </div>

              <Card className="bg-[#2a2a2a]/50 border-gray-800">
                <Table>
                  <TableHeader>
                    <TableRow className="border-gray-700">
                      <TableHead className="text-gray-300">Project</TableHead>
                      <TableHead className="text-gray-300">Client</TableHead>
                      <TableHead className="text-gray-300">Deadline</TableHead>
                      <TableHead className="text-gray-300">Progress</TableHead>
                      <TableHead className="text-gray-300">Status</TableHead>
                      <TableHead className="text-gray-300 text-right">Actions</TableHead>
                    </TableRow>
                  </TableHeader>
                  <TableBody>
                    {assignedProjects.map((project) => (
                      <TableRow key={project.id} className="border-gray-700 hover:bg-gray-800/30">
                        <TableCell>
                          <div className="flex items-center gap-3">
                            <div className="w-10 h-10 bg-gradient-to-br from-[#6B5B95]/20 to-[#9B59B6]/20 rounded-lg flex items-center justify-center">
                              {getCategoryIcon(project.category)}
                            </div>
                            <div>
                              <p className="text-white font-medium">{project.title}</p>
                              <p className="text-xs text-gray-500">{project.category}</p>
                            </div>
                          </div>
                        </TableCell>
                        <TableCell>
                          <p className="text-white">{project.clientName}</p>
                          <p className="text-xs text-gray-500">{project.clientEmail}</p>
                        </TableCell>
                        <TableCell>
                          <p className="text-white">
                            {new Date(project.deadline).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                          </p>
                          <p className="text-xs text-gray-500">{project.location}</p>
                        </TableCell>
                        <TableCell>
                          <div className="w-full max-w-[120px]">
                            <div className="flex items-center justify-between mb-1">
                              <span className="text-xs text-gray-400">{project.progress}%</span>
                            </div>
                            <Progress value={project.progress} className="h-2 bg-gray-800" />
                          </div>
                        </TableCell>
                        <TableCell>{getStatusBadge(project.status)}</TableCell>
                        <TableCell className="text-right">
                          <Button variant="ghost" size="icon" className="text-gray-400 hover:text-white">
                            <MoreVertical className="w-4 h-4" />
                          </Button>
                        </TableCell>
                      </TableRow>
                    ))}
                  </TableBody>
                </Table>
              </Card>

              {/* Completed Projects */}
              <div className="mt-8">
                <h3 className="text-xl font-semibold text-white mb-4">Completed Projects</h3>
                <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                  {assignedProjects.filter(p => p.status === 'completed').map((project) => (
                    <Card key={project.id} className="bg-[#2a2a2a]/50 border-gray-800">
                      <CardContent className="p-4">
                        <div className="flex items-start justify-between mb-3">
                          <div className="flex items-center gap-3">
                            <div className="w-10 h-10 bg-green-500/20 rounded-lg flex items-center justify-center">
                              <Check className="w-5 h-5 text-green-400" />
                            </div>
                            <div>
                              <p className="text-white font-medium">{project.title}</p>
                              <p className="text-xs text-gray-500">{project.clientName}</p>
                            </div>
                          </div>
                          <Badge className="bg-green-500/20 text-green-400">Completed</Badge>
                        </div>
                        <p className="text-xs text-gray-400">
                          Completed on {new Date(project.completedDate!).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
                        </p>
                      </CardContent>
                    </Card>
                  ))}
                </div>
              </div>
            </div>
          )}

          {/* Chat Section */}
          {activeSection === 'chat' && (
            <div className="h-[calc(100vh-140px)]">
              <Card className="h-full bg-[#2a2a2a]/50 border-gray-800">
                <div className="flex h-full">
                  {/* Conversations List */}
                  <div className="w-80 border-r border-gray-800 flex flex-col">
                    <div className="p-4 border-b border-gray-800">
                      <div className="relative">
                        <Search className="absolute left-3 top-1/2 transform -translate-y-1/2 w-4 h-4 text-gray-400" />
                        <Input
                          placeholder="Search conversations..."
                          className="pl-10 bg-gray-800 border-gray-700 text-white placeholder:text-gray-500"
                        />
                      </div>
                    </div>
                    <ScrollArea className="flex-1">
                      {conversations.map((conv) => (
                        <button
                          key={conv.id}
                          onClick={() => setSelectedConversation(conv)}
                          className={`
                            w-full p-4 border-b border-gray-800 text-left transition-colors
                            ${selectedConversation?.id === conv.id
                              ? 'bg-[#6B5B95]/20 border-l-2 border-l-[#6B5B95]'
                              : 'hover:bg-gray-800/50'
                            }
                          `}
                        >
                          <div className="flex items-start gap-3">
                            <div className="relative">
                              <button
                                onClick={(e) => {
                                  e.stopPropagation()
                                  handleViewProfile(conv.clientName)
                                }}
                                className="cursor-pointer hover:opacity-80 transition-opacity"
                              >
                                <Avatar className="w-12 h-12">
                                  <AvatarImage src={conv.clientAvatar} />
                                  <AvatarFallback className="bg-gradient-to-br from-[#9B59B6] to-[#E74C3C] text-white">
                                    {conv.clientName.split(' ').map(n => n[0]).join('')}
                                  </AvatarFallback>
                                </Avatar>
                              </button>
                              {conv.online && (
                                <div className="absolute bottom-0 right-0 w-3 h-3 bg-green-500 rounded-full border-2 border-[#2a2a2a]" />
                              )}
                            </div>
                            <div className="flex-1 min-w-0">
                              <div className="flex items-center justify-between mb-1">
                                <p className="text-white font-medium truncate">{conv.clientName}</p>
                                <p className="text-xs text-gray-500">{conv.lastMessageTime}</p>
                              </div>
                              <p className="text-sm text-gray-400 truncate">{conv.lastMessage}</p>
                              <p className="text-xs text-gray-500 mt-1">{conv.projectTitle}</p>
                            </div>
                            {conv.unreadCount > 0 && (
                              <Badge className="bg-[#E74C3C] text-white text-xs h-5 px-2">
                                {conv.unreadCount}
                              </Badge>
                            )}
                          </div>
                        </button>
                      ))}
                    </ScrollArea>
                  </div>

                  {/* Chat Area */}
                  <div className="flex-1 flex flex-col">
                    {selectedConversation ? (
                      <>
                        {/* Chat Header */}
                        <div className="p-4 border-b border-gray-800 flex items-center justify-between">
                          <button
                            onClick={() => handleViewProfile(selectedConversation.clientName)}
                            className="flex items-center gap-3 hover:bg-gray-800/50 rounded-lg p-2 -m-2 transition-colors"
                          >
                            <Avatar className="w-10 h-10">
                              <AvatarImage src={selectedConversation.clientAvatar} />
                              <AvatarFallback className="bg-gradient-to-br from-[#9B59B6] to-[#E74C3C] text-white">
                                {selectedConversation.clientName.split(' ').map(n => n[0]).join('')}
                              </AvatarFallback>
                            </Avatar>
                            <div>
                              <p className="text-white font-medium">{selectedConversation.clientName}</p>
                              <p className="text-xs text-gray-400">{selectedConversation.projectTitle}</p>
                            </div>
                          </button>
                          <div className="flex items-center gap-2">
                            <Button variant="ghost" size="icon" className="text-gray-400 hover:text-white">
                              <Phone className="w-5 h-5" />
                            </Button>
                            <Button variant="ghost" size="icon" className="text-gray-400 hover:text-white">
                              <VideoIcon className="w-5 h-5" />
                            </Button>
                            <Button variant="ghost" size="icon" className="text-gray-400 hover:text-white">
                              <MoreVertical className="w-5 h-5" />
                            </Button>
                          </div>
                        </div>

                        {/* Messages */}
                        <ScrollArea className="flex-1 p-4">
                          <div className="space-y-4">
                            {messages.map((message) => (
                              <div
                                key={message.id}
                                className={`flex ${message.sender === 'me' ? 'justify-end' : 'justify-start'}`}
                              >
                                <div
                                  className={`
                                    max-w-[70%] rounded-2xl px-4 py-2
                                    ${message.sender === 'me'
                                      ? 'bg-gradient-to-r from-[#6B5B95] to-[#9B59B6] text-white'
                                      : 'bg-gray-800 text-gray-200'
                                    }
                                  `}
                                >
                                  <p className="text-sm">{message.content}</p>
                                  <p className={`text-xs mt-1 ${message.sender === 'me' ? 'text-white/70' : 'text-gray-500'}`}>
                                    {message.timestamp}
                                  </p>
                                </div>
                              </div>
                            ))}
                          </div>
                        </ScrollArea>

                        {/* Message Input */}
                        <div className="p-4 border-t border-gray-800">
                          <div className="flex items-center gap-3">
                            <Button variant="ghost" size="icon" className="text-gray-400 hover:text-white">
                              <Plus className="w-5 h-5" />
                            </Button>
                            <Input
                              placeholder="Type a message..."
                              value={newMessage}
                              onChange={(e) => setNewMessage(e.target.value)}
                              onKeyDown={(e) => e.key === 'Enter' && handleSendMessage()}
                              className="flex-1 bg-gray-800 border-gray-700 text-white placeholder:text-gray-500"
                            />
                            <Button
                              onClick={handleSendMessage}
                              className="bg-gradient-to-r from-[#6B5B95] to-[#9B59B6] hover:from-[#5a4a7e] hover:to-[#8a4a9f]"
                            >
                              <Send className="w-5 h-5" />
                            </Button>
                          </div>
                        </div>
                      </>
                    ) : (
                      <div className="flex-1 flex items-center justify-center">
                        <div className="text-center">
                          <MessageCircle className="w-16 h-16 mx-auto text-gray-700 mb-4" />
                          <p className="text-gray-400">Select a conversation to start chatting</p>
                        </div>
                      </div>
                    )}
                  </div>
                </div>
              </Card>
            </div>
          )}

          {/* Video Meetings Section */}
          {activeSection === 'meetings' && (
            <div className="space-y-6">
              <div className="flex items-center justify-between">
                <div>
                  <h3 className="text-xl font-semibold text-white">Video Meetings</h3>
                  <p className="text-gray-400 text-sm mt-1">
                    {videoMeetings.filter(m => m.status === 'scheduled').length} upcoming meetings
                  </p>
                </div>
                <Button className="bg-gradient-to-r from-[#6B5B95] to-[#9B59B6] hover:from-[#5a4a7e] hover:to-[#8a4a9f]">
                  <Plus className="w-4 h-4 mr-2" />
                  Schedule Meeting
                </Button>
              </div>

              {/* Upcoming Meetings */}
              <div>
                <h4 className="text-lg font-medium text-white mb-4">Upcoming Meetings</h4>
                <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                  {videoMeetings.filter(m => m.status === 'scheduled').map((meeting) => (
                    <Card key={meeting.id} className="bg-[#2a2a2a]/50 border-gray-800 hover:border-[#6B5B95]/50 transition-colors">
                      <CardContent className="p-6">
                        <div className="flex items-start justify-between mb-4">
                          <div className="flex items-start gap-3">
                            <div className="w-12 h-12 bg-gradient-to-br from-[#6B5B95]/20 to-[#9B59B6]/20 rounded-xl flex items-center justify-center flex-shrink-0">
                              <Video className="w-6 h-6 text-[#9B59B6]" />
                            </div>
                            <div>
                              <h5 className="text-white font-semibold">{meeting.projectTitle}</h5>
                              <p className="text-sm text-gray-400 mt-1">{meeting.description}</p>
                            </div>
                          </div>
                          {getStatusBadge(meeting.status)}
                        </div>

                        <div className="space-y-3 mb-4">
                          <div className="flex items-center gap-2 text-sm">
                            <User className="w-4 h-4 text-gray-400" />
                            <span className="text-gray-300">{meeting.clientName}</span>
                          </div>
                          <div className="flex items-center gap-2 text-sm">
                            <Calendar className="w-4 h-4 text-gray-400" />
                            <span className="text-gray-300">
                              {new Date(meeting.scheduledTime).toLocaleDateString('en-US', {
                                weekday: 'long',
                                month: 'long',
                                day: 'numeric',
                                year: 'numeric'
                              })}
                            </span>
                          </div>
                          <div className="flex items-center gap-2 text-sm">
                            <Clock className="w-4 h-4 text-gray-400" />
                            <span className="text-gray-300">
                              {new Date(meeting.scheduledTime).toLocaleTimeString('en-US', {
                                hour: '2-digit',
                                minute: '2-digit'
                              })}
                              {' · '}{meeting.duration} min
                            </span>
                          </div>
                        </div>

                        <Button
                          onClick={() => handleStartMeeting(meeting.id)}
                          className="w-full bg-gradient-to-r from-[#6B5B95] to-[#9B59B6] hover:from-[#5a4a7e] hover:to-[#8a4a9f]"
                        >
                          <Play className="w-4 h-4 mr-2" />
                          Start Meeting
                        </Button>
                      </CardContent>
                    </Card>
                  ))}
                </div>
              </div>

              {/* Meeting History */}
              <div className="mt-8">
                <h4 className="text-lg font-medium text-white mb-4">Meeting History</h4>
                <Card className="bg-[#2a2a2a]/50 border-gray-800">
                  <Table>
                    <TableHeader>
                      <TableRow className="border-gray-700">
                        <TableHead className="text-gray-300">Project</TableHead>
                        <TableHead className="text-gray-300">Client</TableHead>
                        <TableHead className="text-gray-300">Date & Time</TableHead>
                        <TableHead className="text-gray-300">Duration</TableHead>
                        <TableHead className="text-gray-300">Status</TableHead>
                      </TableRow>
                    </TableHeader>
                    <TableBody>
                      {videoMeetings.filter(m => m.status !== 'scheduled').map((meeting) => (
                        <TableRow key={meeting.id} className="border-gray-700">
                          <TableCell className="text-white">{meeting.projectTitle}</TableCell>
                          <TableCell className="text-white">{meeting.clientName}</TableCell>
                          <TableCell className="text-white">
                            {new Date(meeting.scheduledTime).toLocaleDateString('en-US', {
                              month: 'short',
                              day: 'numeric',
                              year: 'numeric'
                            })}
                            {' at '}
                            {new Date(meeting.scheduledTime).toLocaleTimeString('en-US', {
                              hour: '2-digit',
                              minute: '2-digit'
                            })}
                          </TableCell>
                          <TableCell className="text-white">{meeting.duration} min</TableCell>
                          <TableCell>{getStatusBadge(meeting.status)}</TableCell>
                        </TableRow>
                      ))}
                    </TableBody>
                  </Table>
                </Card>
              </div>
            </div>
          )}

          {/* My Projects Section */}
          {activeSection === 'projects' && (
            <div className="space-y-6">
              <div className="flex items-center justify-between">
                <div>
                  <h3 className="text-xl font-semibold text-white">All My Projects</h3>
                  <p className="text-gray-400 text-sm mt-1">{user.totalProjects} total projects</p>
                </div>
              </div>

              <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {assignedProjects.map((project) => (
                  <Card key={project.id} className="bg-[#2a2a2a]/50 border-gray-800 hover:border-[#6B5B95]/50 transition-all hover:shadow-lg hover:shadow-[#6B5B95]/10">
                    <CardHeader>
                      <div className="flex items-start justify-between">
                        <div className="w-12 h-12 bg-gradient-to-br from-[#6B5B95]/20 to-[#9B59B6]/20 rounded-xl flex items-center justify-center">
                          {getCategoryIcon(project.category)}
                        </div>
                        {getStatusBadge(project.status)}
                      </div>
                      <CardTitle className="text-white mt-4">{project.title}</CardTitle>
                      <CardDescription className="text-gray-400">{project.category}</CardDescription>
                    </CardHeader>
                    <CardContent className="space-y-4">
                      <div className="space-y-2">
                        <div className="flex justify-between text-sm">
                          <span className="text-gray-400">Progress</span>
                          <span className="text-white">{project.progress}%</span>
                        </div>
                        <Progress value={project.progress} className="h-2 bg-gray-800" />
                      </div>

                      <div className="space-y-2 text-sm">
                        <div className="flex items-center gap-2 text-gray-300">
                          <MapPin className="w-4 h-4 text-[#E74C3C]" />
                          {project.location}
                        </div>
                        <div className="flex items-center gap-2 text-gray-300">
                          <Calendar className="w-4 h-4 text-[#9B59B6]" />
                          {new Date(project.deadline).toLocaleDateString('en-US', {
                            month: 'short',
                            day: 'numeric',
                            year: 'numeric'
                          })}
                        </div>
                        <div className="flex items-center gap-2 text-gray-300">
                          <User className="w-4 h-4 text-[#6B5B95]" />
                          {project.clientName}
                        </div>
                      </div>

                      <div className="flex items-center gap-2">
                        <Button
                          variant="ghost"
                          size="sm"
                          onClick={() => handleViewProfile(project.clientName)}
                          className="flex-1 text-[#9B59B6] hover:text-[#9B59B6] hover:bg-[#6B5B95]/10"
                        >
                          View Team
                        </Button>
                        <Button
                          variant="outline"
                          className="flex-1 bg-[#6B5B95]/10 border-[#6B5B95]/30 text-[#9B59B6] hover:bg-[#6B5B95]/20"
                        >
                          View Details
                          <ChevronRight className="w-4 h-4 ml-2" />
                        </Button>
                      </div>
                    </CardContent>
                  </Card>
                ))}
              </div>
            </div>
          )}

          {/* Portfolio Section */}
          {activeSection === 'portfolio' && (
            <div className="space-y-6">
              <div className="flex items-center justify-between">
                <div>
                  <h3 className="text-xl font-semibold text-white">My Portfolio</h3>
                  <p className="text-gray-400 text-sm mt-1">Showcase your completed projects</p>
                </div>
                <Button className="bg-gradient-to-r from-[#6B5B95] to-[#9B59B6] hover:from-[#5a4a7e] hover:to-[#8a4a9f]">
                  <Plus className="w-4 h-4 mr-2" />
                  Add Project
                </Button>
              </div>

              <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {[1, 2, 3, 4, 5, 6].map((item) => (
                  <Card key={item} className="bg-[#2a2a2a]/50 border-gray-800 overflow-hidden group">
                    <div className="h-48 bg-gradient-to-br from-[#6B5B95]/30 to-[#9B59B6]/30 relative overflow-hidden">
                      <div className="absolute inset-0 flex items-center justify-center">
                        <ImageIcon className="w-16 h-16 text-[#6B5B95]/50" />
                      </div>
                      <div className="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center gap-3">
                        <Button size="sm" variant="secondary" className="bg-white/20 backdrop-blur-sm">
                          <Eye className="w-4 h-4 mr-2" />
                          View
                        </Button>
                        <Button size="sm" variant="secondary" className="bg-white/20 backdrop-blur-sm">
                          <Settings className="w-4 h-4 mr-2" />
                          Edit
                        </Button>
                      </div>
                    </div>
                    <CardContent className="p-4">
                      <h4 className="text-white font-medium">Project Title {item}</h4>
                      <p className="text-sm text-gray-400 mt-1">Project description goes here</p>
                      <div className="flex items-center gap-2 mt-3">
                        <Badge variant="outline" className="bg-[#6B5B95]/20 text-[#9B59B6] border-[#6B5B95]/30">
                          Villa
                        </Badge>
                        <Badge variant="outline" className="bg-gray-800 text-gray-300 border-gray-700">
                          2024
                        </Badge>
                      </div>
                    </CardContent>
                  </Card>
                ))}
              </div>
            </div>
          )}

          {/* Profile Section */}
          {activeSection === 'profile' && (
            <div className="space-y-6">
              <Card className="bg-[#2a2a2a]/50 border-gray-800">
                <CardHeader>
                  <CardTitle className="text-white">Profile Settings</CardTitle>
                  <CardDescription className="text-gray-400">Manage your profile and expertise</CardDescription>
                </CardHeader>
                <CardContent className="space-y-6">
                  {/* Profile Picture */}
                  <div className="flex items-center gap-6">
                    <Avatar className="w-24 h-24">
                      <AvatarImage src={user.avatar} />
                      <AvatarFallback className="bg-gradient-to-br from-[#6B5B95] to-[#9B59B6] text-white text-2xl">
                        {user.name.split(' ').map(n => n[0]).join('')}
                      </AvatarFallback>
                    </Avatar>
                    <div>
                      <Button variant="outline" size="sm" className="bg-[#2a2a2a] border-gray-700 text-white">
                        Change Photo
                      </Button>
                      <p className="text-xs text-gray-500 mt-2">JPG, PNG or GIF. Max size 2MB</p>
                    </div>
                  </div>

                  <Separator className="bg-gray-700" />

                  {/* Personal Information */}
                  <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div className="space-y-2">
                      <Label className="text-gray-300">Full Name</Label>
                      <Input
                        defaultValue={user.name}
                        className="bg-gray-800 border-gray-700 text-white"
                      />
                    </div>
                    <div className="space-y-2">
                      <Label className="text-gray-300">Email</Label>
                      <Input
                        defaultValue={user.email}
                        className="bg-gray-800 border-gray-700 text-white"
                      />
                    </div>
                    <div className="space-y-2">
                      <Label className="text-gray-300">Phone Number</Label>
                      <Input
                        placeholder="+62 xxx xxxx xxxx"
                        className="bg-gray-800 border-gray-700 text-white"
                      />
                    </div>
                    <div className="space-y-2">
                      <Label className="text-gray-300">Location</Label>
                      <Input
                        placeholder="City, Country"
                        className="bg-gray-800 border-gray-700 text-white"
                      />
                    </div>
                  </div>

                  <Separator className="bg-gray-700" />

                  {/* Bio */}
                  <div className="space-y-2">
                    <Label className="text-gray-300">Bio</Label>
                    <Textarea
                      placeholder="Tell us about yourself and your experience..."
                      className="bg-gray-800 border-gray-700 text-white min-h-[120px]"
                    />
                  </div>

                  <Separator className="bg-gray-700" />

                  {/* Expertise Areas */}
                  <div className="space-y-3">
                    <Label className="text-gray-300">Expertise Areas</Label>
                    <div className="grid grid-cols-2 md:grid-cols-3 gap-3">
                      {['Residential', 'Villa', 'Cafe & Resto', 'Commercial', 'Hospital', 'Apartment'].map((expertise) => (
                        <Button
                          key={expertise}
                          variant="outline"
                          className={`
                            justify-start
                            ${user.skills.some(s => s.expertise === expertise)
                              ? 'bg-[#6B5B95]/20 border-[#6B5B95]/50 text-white'
                              : 'bg-gray-800 border-gray-700 text-gray-400'
                            }
                          `}
                        >
                          <Check className={`w-4 h-4 mr-2 ${user.skills.some(s => s.expertise === expertise) ? 'opacity-100' : 'opacity-0'}`} />
                          {expertise}
                        </Button>
                      ))}
                    </div>
                  </div>

                  <Separator className="bg-gray-700" />

                  {/* Building Types (for licensed architects) */}
                  {user.profession === 'licensed_architect' && (
                    <div className="space-y-3">
                      <Label className="text-gray-300">Licensed Building Types</Label>
                      <div className="grid grid-cols-3 gap-3">
                        {['Low-rise', 'Mid-rise', 'High-rise'].map((type) => (
                          <Button
                            key={type}
                            variant="outline"
                            className={`
                              justify-center
                              bg-gray-800 border-gray-700 text-gray-400
                            `}
                          >
                            {type}
                          </Button>
                        ))}
                      </div>
                    </div>
                  )}

                  <div className="flex justify-end gap-3 pt-4">
                    <Button variant="outline" className="bg-gray-800 border-gray-700 text-white">
                      Cancel
                    </Button>
                    <Button className="bg-gradient-to-r from-[#6B5B95] to-[#9B59B6] hover:from-[#5a4a7e] hover:to-[#8a4a9f]">
                      Save Changes
                    </Button>
                  </div>
                </CardContent>
              </Card>
            </div>
          )}
        </div>
      </main>

      {/* Profile Modal */}
      <ProfileModal
        memberId={selectedMemberId}
        open={profileModalOpen}
        onOpenChange={setProfileModalOpen}
      />

      {/* Project Details Dialog */}
      <Dialog open={!!selectedProject} onOpenChange={() => setSelectedProject(null)}>
        <DialogContent className="bg-[#2a2a2a] border-gray-700 text-white max-w-2xl max-h-[80vh] overflow-y-auto">
          {selectedProject && (
            <>
              <DialogHeader>
                <DialogTitle className="text-2xl">{selectedProject.title}</DialogTitle>
                <DialogDescription className="text-gray-400">
                  Project Request Details
                </DialogDescription>
              </DialogHeader>
              <div className="space-y-4 mt-4">
                <div className="flex items-center gap-2">
                  {getCategoryIcon(selectedProject.category)}
                  <Badge variant="outline" className="bg-[#6B5B95]/20 text-[#9B59B6] border-[#6B5B95]/30">
                    {selectedProject.category}
                  </Badge>
                  {selectedProject.buildingType && (
                    <Badge variant="outline" className="bg-gray-800 text-gray-300 border-gray-700">
                      {selectedProject.buildingType}
                    </Badge>
                  )}
                </div>

                <p className="text-gray-300">{selectedProject.description}</p>

                <div className="grid grid-cols-2 gap-4">
                  <div>
                    <p className="text-sm text-gray-500 mb-1">Budget</p>
                    <p className="text-white flex items-center gap-2">
                      <DollarSign className="w-4 h-4 text-[#F39C12]" />
                      {selectedProject.budget}
                    </p>
                  </div>
                  <div>
                    <p className="text-sm text-gray-500 mb-1">Location</p>
                    <p className="text-white flex items-center gap-2">
                      <MapPin className="w-4 h-4 text-[#E74C3C]" />
                      {selectedProject.location}
                    </p>
                  </div>
                  <div>
                    <p className="text-sm text-gray-500 mb-1">Deadline</p>
                    <p className="text-white flex items-center gap-2">
                      <Calendar className="w-4 h-4 text-[#9B59B6]" />
                      {new Date(selectedProject.deadline).toLocaleDateString('en-US', {
                        month: 'long',
                        day: 'numeric',
                        year: 'numeric'
                      })}
                    </p>
                  </div>
                </div>

                <Separator className="bg-gray-700" />

                <div>
                  <p className="text-sm text-gray-500 mb-2">Client Information</p>
                  <div className="space-y-2">
                    <p className="text-white flex items-center gap-2">
                      <User className="w-4 h-4 text-gray-400" />
                      {selectedProject.clientName}
                    </p>
                    <p className="text-white flex items-center gap-2">
                      <Mail className="w-4 h-4 text-gray-400" />
                      {selectedProject.clientEmail}
                    </p>
                    <p className="text-white flex items-center gap-2">
                      <Phone className="w-4 h-4 text-gray-400" />
                      {selectedProject.clientPhone}
                    </p>
                  </div>
                </div>

                <div className="flex items-center justify-end gap-3 pt-4">
                  <Button
                    variant="outline"
                    onClick={() => handleDeclineProject(selectedProject.id)}
                    className="bg-red-500/10 border-red-500/30 text-red-400 hover:bg-red-500/20"
                  >
                    <X className="w-4 h-4 mr-2" />
                    Decline
                  </Button>
                  {selectedProject.expertiseMatch ? (
                    <Button
                      onClick={() => handleAcceptProject(selectedProject.id)}
                      className="bg-gradient-to-r from-[#6B5B95] to-[#9B59B6] hover:from-[#5a4a7e] hover:to-[#8a4a9f]"
                    >
                      <Check className="w-4 h-4 mr-2" />
                      Accept Project
                    </Button>
                  ) : (
                    <Button
                      onClick={() => handleApplyAsAssistant(selectedProject.id)}
                      className="bg-gradient-to-r from-[#F39C12] to-[#F1C40F] hover:from-[#e08b11] hover:to-[#e0d410] text-black"
                    >
                      <Award className="w-4 h-4 mr-2" />
                      Apply as Assistant
                    </Button>
                  )}
                </div>
              </div>
            </>
          )}
        </DialogContent>
      </Dialog>
    </div>
  )
}

