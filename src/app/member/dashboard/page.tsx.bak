// TypeScript Types
interface ProjectRequest {
  id: string
  title: string
  category: 'Residential' | 'Hospital' | 'Villa' | 'Cafe & Resto' | 'Apartment' | 'Commercial'
  buildingType?: 'Low-rise' | 'Mid-rise' | 'High-rise'
  budget: string
  location: string
  deadline: string
  description: string
  clientName: string
  clientEmail: string
  clientPhone: string
  expertiseMatch: boolean
  matchedExpertise?: string
  status: 'pending' | 'accepted' | 'declined' | 'completed'
  createdAt: string
}

interface AssignedProject {
  id: string
  title: string
  category: string
  buildingType?: string
  budget: string
  location: string
  deadline: string
  status: 'pending' | 'in_progress' | 'review' | 'completed'
  clientName: string
  clientEmail: string
  clientPhone: string
  startDate?: string
  completedDate?: string
  progress: number
}

interface Conversation {
  id: string
  clientName: string
  clientAvatar?: string
  projectId: string
  projectTitle: string
  lastMessage: string
  lastMessageTime: string
  unreadCount: number
  online: boolean
}

interface Message {
  id: string
  sender: 'me' | 'client'
  content: string
  timestamp: string
  read: boolean
}

interface VideoMeeting {
  id: string
  clientId: string
  clientName: string
  projectTitle: string
  scheduledTime: string
  duration: number
  status: 'scheduled' | 'ongoing' | 'completed' | 'cancelled'
  meetingUrl: string
  description?: string
}

interface UserSkill {
  expertise: string
  assistantProjectsCompleted: number
  requiredProjects: number
  currentStatus: 'Assistant' | 'Architect'
}

interface User {
  id: string
  name: string
  email: string
  avatar?: string
  profession: 'architect' | 'licensed_architect' | 'assistant'
  skills: UserSkill[]
  totalProjects: number
  completedProjects: number
  activeProjects: number
  pendingReviews: number
  rating: number
  memberSince: string
}

